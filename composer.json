{
  "name": "bizlink/crm-platform",
  "description": "BizLink CRM backend test setup",
  "type": "project",
  "require": {},
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "files": [
      "api/auth_token_utils.php",
      "api/api_helpers.php"
    ]
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "test:unit": "phpunit --configuration phpunit.xml --testsuite Unit",
    "test:integration": "phpunit --configuration phpunit.xml --testsuite Integration"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
