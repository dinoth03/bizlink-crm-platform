# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=bizlink_crm
DB_PORT=3306

# Security Configuration
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CSRF_ENABLED=true
SECURITY_HEADERS_ENABLED=true

# JWT Configuration
